# ASR 7-Agent System — Environment Variables
# Copy to .env and fill in your values

# ── REQUIRED ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-key-here

# ── AGENT 1 — LEADS ──────────────────────────────────────────
SERPAPI_API_KEY=your-serpapi-key              # serpapi.com — free 100/month

# ── AGENT 2 — OUTREACH ───────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=srijan@asrecruitment.in            # your Gmail
EMAIL_PASS=your-app-password                  # Gmail App Password (not your main password)
EMAIL_FROM=srijan@asrecruitment.in

# WhatsApp Business API (use AiSensy/Wati for easy setup — ₹999/month)
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_ID=your-phone-number-id        # from Meta Business Dashboard

# ── AGENT 3 — MEETINGS ───────────────────────────────────────
CALENDLY_LINK=https://calendly.com/asrecruitment/30min
# CALENDLY_API_KEY=your-calendly-key          # optional for auto-tracking

# ── AGENT 4 — CANDIDATES ─────────────────────────────────────
GOOGLE_SHEET_ID=your-google-sheet-id
GOOGLE_CREDS_JSON=credentials.json
GOOGLE_FORM_CSV=form_responses.csv            # export from Google Forms

# ── AGENT 5 — RESUME PARSER ──────────────────────────────────
RESUME_DIR=resumes/                           # drop PDFs here

# ── AGENT 6 — MATCHING ───────────────────────────────────────
# Uses candidate database from asr_candidate_engine.py
# Copy asr_candidate_engine.py into this folder

# ── AGENT 7 — INTERVIEWS ─────────────────────────────────────
# Uses WHATSAPP_API_KEY from above
# Google Calendar integration (optional)
# GOOGLE_CALENDAR_KEY=your-calendar-key
